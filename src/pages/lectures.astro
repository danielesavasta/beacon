---
import Base from '../layouts/Base.astro';
import { getLangFromUrl, type Locale, useTranslations } from '../i18n/utils';
import { getEntry, render } from 'astro:content';

export interface Props {
  lang?: Locale;
}

const lang = (Astro.props.lang ?? getLangFromUrl(Astro.url)) as Locale;
const t = useTranslations(lang);
const entry = await getEntry('lectures', lang);
if (!entry) {
  throw new Error(`Missing lectures content for locale: ${lang}`);
}
const { Content } = await render(entry);
const sessions = entry.data.sessions;
---

<Base title={t('lectures.title')} lang={lang} t={t}>
  <div class="page-header container">
    <h1>{t('lectures.title')}</h1>
  </div>
  <section class="section container prose">
    <Content />
  </section>

  <section class="section container prose">
    <div class="lectures-grid">
      {sessions.map((session) => (
        <article class="lecture-card">
          <div class="lecture-card__embed">
            <iframe
              src={`https://www.youtube-nocookie.com/embed/${session.youtubeId}`}
              title={session.label}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
          <div class="lecture-card__body">
            <h2 class="lecture-card__title">{session.label}</h2>
            {session.daily && session.daily.length > 0 && (
              <ul class="lecture-card__daily" role="list">
                {session.daily.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            )}
            <a class="btn btn--secondary" href={`https://www.youtube.com/watch?v=${session.youtubeId}`} target="_blank" rel="noopener noreferrer">
              {t('lectures.watch')}
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</Base>
