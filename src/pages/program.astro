---
import Base from '../layouts/Base.astro';
import { getLangFromUrl, type Locale, useTranslations } from '../i18n/utils';
import { getEntry, render } from 'astro:content';

export interface Props {
  lang?: Locale;
}

const lang = (Astro.props.lang ?? getLangFromUrl(Astro.url)) as Locale;
const t = useTranslations(lang);
const entry = await getEntry('program', lang);
if (!entry) {
  throw new Error(`Missing program content for locale: ${lang}`);
}
const { Content } = await render(entry);
---

<Base title={t('program.title')} lang={lang} t={t}>
  <div class="page-header container">
    <h1>{t('program.title')}</h1>
  </div>
  <section class="section container prose">
    <Content />
  </section>
</Base>
