---
import Base from '../layouts/Base.astro';
import { getLangFromUrl, type Locale, useTranslations } from '../i18n/utils';
import { getEntry, render } from 'astro:content';

export interface Props {
  lang?: Locale;
}

const lang = (Astro.props.lang ?? getLangFromUrl(Astro.url)) as Locale;
const t = useTranslations(lang);
const entry = await getEntry('about', lang);
if (!entry) {
  throw new Error(`Missing about content for locale: ${lang}`);
}
const { Content } = await render(entry);
const partners = entry.data.partners;
const base = import.meta.env.BASE_URL;
---

<Base title={t('about.title')} lang={lang} t={t}>
  <div class="page-header container">
    <h1>{t('about.title')}</h1>
    <div class="about-intro prose"><Content /></div>
  </div>
  <section class="section container" aria-labelledby="partners-heading">
    <h3 id="partners-heading">{t('about.partners_title')}</h3>
    <div class="partners-grid">
      {partners.map((p) => (
        <article class="partner-card">
          <div class="partner-card__header">
            {p.logo && <img class="partner-card__logo" src={`${base}partners/${p.logo}`} alt={p.name} />}
            <h3 class="partner-card__name">{p.name}</h3>
            {p.location && <p class="partner-card__location text-muted">{p.location}</p>}
            {p.url && <a class="partner-card__link" href={p.url} target="_blank" rel="noopener noreferrer">{p.url.replace(/^https?:\/\//, '')}</a>}
          </div>
          {p.people.length > 0 && <ul class="partner-card__people" role="list">{p.people.map((person) => <li>{person}</li>)}</ul>}
          {p.students.length > 0 && (
            <!-- <details class="partner-card__students">
              <summary>Students ({p.students.length})</summary>-->
              <ul role="list">{p.students.map((s) => <li>{s}</li>)}</ul>
            <!-- <details>-->
          )}
        </article>
      ))}
    </div>
  </section>
  <section class="section container" aria-labelledby="identity-heading">
    <h3 id="identity-heading">{t('about.identity_title')}</h3>
    <a href={`${base}BIP_visual identity.pdf`} target="_blank" rel="noopener noreferrer"><img src={`${base}beacon.png`} alt="Beacon Logo">Download identity assets</a>
    <p class="text-italic">Visual identity developed by Elia Maniscalco.</p>
  </section>
</Base>
