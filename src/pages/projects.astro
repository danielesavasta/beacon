---
import Base from '../layouts/Base.astro';
import '../styles/components/card.css';
import { getLangFromUrl, type Locale, useTranslations } from '../i18n/utils';
import { getCollection, getEntry, render } from 'astro:content';
import { hasProjectMedia } from '../utils/projectMedia';

export interface Props {
  lang?: Locale;
}

const lang = (Astro.props.lang ?? getLangFromUrl(Astro.url)) as Locale;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
const basePath = lang === 'en' ? base : `${base}${lang}/`;
const entry = await getEntry('projects', lang);
if (!entry) {
  throw new Error(`Missing projects content for locale: ${lang}`);
}
const { Content } = await render(entry);
const projectItems = (await getCollection('projectItems')).filter(p => hasProjectMedia(p.data.group));
---

<Base title={t('projects.title')} lang={lang} t={t}>
  <div class="page-header container">
    <h1>{t('projects.title')}</h1>
  </div>
  <section class="section container">
    <div class="card-grid">
      <article class="card">
        <div class="card__body">
          <h2 class="card__title">{t('alphabet.title')}</h2>
          <p class="card__text">{t('alphabet.description')}</p>
          <a class="btn btn--secondary" href={`${basePath}alphabet/`}>{t('projects.watch')}</a>
        </div>
      </article>

      <article class="card">
        <div class="card__body">
          <h2 class="card__title">{t('alphabet2.title')}</h2>
          <p class="card__text">{t('alphabet2.description')}</p>
          <a class="btn btn--secondary" href={`${basePath}alphabet2/`}>{t('projects.watch')}</a>
        </div>
      </article>
    </div>
  </section>
  <section class="section container prose">
    <Content />
  </section>
  {projectItems.length > 0 && (
    <section class="section container">
      <div class="card-grid">
        {projectItems.map((project) => (
          <article class="card">
            <div class="card__body">
              <h2 class="card__title">{project.data.title}</h2>
              <p class="card__text">{project.data.authors.join(', ')}</p>
              <a class="btn btn--secondary" href={`${basePath}projects/${project.id}/`}>
                {t('card.readMore')}
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}
</Base>
