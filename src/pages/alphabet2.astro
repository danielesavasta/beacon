---
import Base from '../layouts/Base.astro';
import '../styles/components/alphabet.css';
import { getLangFromUrl, type Locale, useTranslations } from '../i18n/utils';

export interface Props {
  lang?: Locale;
}

const lang = (Astro.props.lang ?? getLangFromUrl(Astro.url)) as Locale;
const t = useTranslations(lang);

---

<Base title={t('alphabet2.title')} lang={lang} t={t} mainClass="alphabet-page">
  <div class="page-header container">
    <h1>{t('alphabet2.title')}</h1>
  </div>
<section class="section container prose">
  <video class="hero__video" autoplay muted loop playsinline aria-hidden="true">
    <source src={`${import.meta.env.BASE_URL}alphabet/alphabet-of-european-values.mp4`} type="video/mp4" />
  </video>
  
  </section>
</Base>
