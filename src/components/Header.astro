---
import LangSwitcher from './LangSwitcher.astro';
import { type Locale } from '../i18n/utils';
import '../styles/components/header.css';

export interface Props {
  lang: Locale;
  t: (key: string) => string;
  hideLogo?: boolean;
}

const { lang, t, hideLogo = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const basePath = lang === 'en' ? base : `${base}${lang}/`;
---

<header class="site-header">
  <div class="site-header__inner container">
      <button
        class="site-nav__toggle"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label={t('nav.toggle')}
      >
        <span class="site-nav__bar" aria-hidden="true"></span>
        <span class="site-nav__bar" aria-hidden="true"></span>
        <span class="site-nav__bar" aria-hidden="true"></span>
      </button>
      


    <nav class="site-nav" aria-label={t('nav.label')}>
      <ul class="site-nav__list" role="list" id="mobile-menu">
        <li><a class="site-nav__link" href={basePath}>{t('nav.home')}</a></li>
        <li><a class="site-nav__link" href={`${basePath}program/`}>{t('nav.program')}</a></li>
        <li><a class="site-nav__link" href={`${basePath}journal/`}>{t('nav.journal')}</a></li>
        <li><a class="site-nav__link" href={`${basePath}lectures/`}>{t('nav.lectures')}</a></li>
        <li><a class="site-nav__link" href={`${basePath}projects/`}>{t('nav.projects')}</a></li>
        <li>
          <a class="site-nav__link" href={`${basePath}about/`}>{t('nav.about')}</a>
        </li>
      </ul>
    </nav>

    <div class="site-header__actions">
      <LangSwitcher currentLang={lang} currentPath={Astro.url.pathname} t={t} />
      <button
        class="theme-toggle"
        type="button"
        aria-pressed="false"
        aria-label={t('nav.theme')}
      >
        <svg
          class="theme-toggle__icon"
          viewBox="0 0 239.71 239.71"
          aria-hidden="true"
          focusable="false"
        >
          <path d="M119.85,239.71C53.77,239.71,0,185.94,0,119.85S53.77,0,119.85,0s119.85,53.77,119.85,119.85-53.77,119.85-119.85,119.85ZM119.85,21c-54.51,0-98.85,44.35-98.85,98.85s44.35,98.85,98.85,98.85,98.85-44.35,98.85-98.85S174.36,21,119.85,21Z" />
          <path d="M119.85,201.12c44.88,0,81.27-36.39,81.27-81.27s-36.39-81.27-81.27-81.27v162.54Z" />
        </svg>
      </button>

    </div>
  </div>
  
</header>

<script>
  const toggle = document.querySelector('.site-nav__toggle') as HTMLButtonElement | null;
  const menu   = document.querySelector('#mobile-menu') as HTMLElement | null;
  const themeToggle = document.querySelector('.theme-toggle') as HTMLButtonElement | null;
  const root = document.documentElement;
  const colorSchemeQuery = window.matchMedia('(prefers-color-scheme: dark)');

  const getStoredTheme = () => {
    const theme = localStorage.getItem('theme');
    return theme === 'light' || theme === 'dark' ? theme : null;
  };

  const getActiveTheme = () => {
    return getStoredTheme() ?? (colorSchemeQuery.matches ? 'dark' : 'light');
  };

  const syncThemeToggle = () => {
    if (!themeToggle) return;

    const activeTheme = getActiveTheme();
    const isDark = activeTheme === 'dark';

    themeToggle.setAttribute('aria-pressed', String(isDark));
    themeToggle.dataset.theme = activeTheme;
  };

  const setTheme = (theme: 'light' | 'dark') => {
    root.dataset.theme = theme;
    localStorage.setItem('theme', theme);
    syncThemeToggle();
  };

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(isOpen));
  });

  themeToggle?.addEventListener('click', () => {
    const nextTheme = getActiveTheme() === 'dark' ? 'light' : 'dark';
    setTheme(nextTheme);
  });

  colorSchemeQuery.addEventListener('change', () => {
    if (!getStoredTheme()) {
      root.dataset.theme = colorSchemeQuery.matches ? 'dark' : 'light';
      syncThemeToggle();
    }
  });

  syncThemeToggle();

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!toggle?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      menu?.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      menu?.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
