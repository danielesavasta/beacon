---
import '../styles/tokens.css';
import '../styles/reset.css';
import '../styles/typography.css';
import '../styles/utilities.css';
import '../styles/components/pages.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { type Locale } from '../i18n/utils';

export interface Props {
  title: string;
  description?: string;
  lang: Locale;
  t: (key: string) => string;
  hideHeaderLogo?: boolean;
  mainClass?: string;
}


const { title, description = 'Beacon — Building a Visual Alphabet for the European Values | BIP 2024-1-IT02-KA131-HED-000197121-2', lang, t, hideHeaderLogo = false, mainClass } = Astro.props;
const base = import.meta.env.BASE_URL;
const mainBackgroundImage = `url('${base}beacon_logo.svg')`;

---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Beacon BIP</title>
    <link rel="icon" type="image/svg+xml" href={`${base}beacon_logo.svg`} />
    <!-- Alternate language links -->
    <link rel="alternate" hreflang="en" href={base} />
    <link rel="alternate" hreflang="it" href={`${base}it/`} />
    <link rel="alternate" hreflang="pl" href={`${base}pl/`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=News+Cycle:wght@400;700&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" />
    <script is:inline>
      (() => {
        const storedTheme = localStorage.getItem('theme');
        const hasStoredTheme = storedTheme === 'light' || storedTheme === 'dark';
        const resolvedTheme = hasStoredTheme
          ? storedTheme
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

        document.documentElement.dataset.theme = resolvedTheme;
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{lang === 'it' ? 'Vai al contenuto' : lang === 'en' ? 'Skip to content' : 'Przejdź do treści'}</a>
    <Header lang={lang} t={t} hideLogo={hideHeaderLogo} />
    <main id="main-content" class:list={['main', { 'main--no-bg': hideHeaderLogo }, mainClass]} style={`--main-bg-image: ${mainBackgroundImage};`}>
      <slot />
    </main>
    <Footer lang={lang} t={t} />
  </body>
</html>
